#!/bin/sh
# 模板:提交前门禁(L1)。谁填:把 {占位命令} 换成项目真实命令;没有对应工具的整段删掉——空壳门禁比没有门禁更糟(假安全感)。
# 安装(必做,hook 不随 clone 自动生效):git config core.hooksPath .githooks
#   建议把这行写进项目的安装脚本或 package.json 的 "prepare",保证每个 clone 都装上。
# 结构:每段一个门禁,不过就阻止提交;临时跳过用 git commit --no-verify(跳过本身应有理由并留痕)。

# ── 门禁 1:类型检查(没有类型系统的项目删掉本段) ──
echo "[pre-commit] 类型检查..."
if ! {类型检查命令,如 npm run -s typecheck}; then
  echo "[pre-commit] 类型检查未通过 — 提交已阻止,修复后重试"
  exit 1
fi

# ── 门禁 2:快速测试(测试太慢就只跑受影响子集或删掉本段、留给 CI) ──
echo "[pre-commit] 测试..."
if ! {测试命令,如 npm test -s}; then
  echo "[pre-commit] 测试未通过 — 提交已阻止,修复后重试"
  exit 1
fi

# ── 门禁 3:治理 lint(若你写了结构校验脚本:关键文件存在/断链/流水完成度;没有就删掉本段) ──
echo "[pre-commit] 治理 lint..."
if ! {治理 lint 命令,如 node scripts/governance-lint.mjs}; then
  echo "[pre-commit] 治理 lint 未通过 — 提交已阻止,修复后重试"
  exit 1
fi

echo "[pre-commit] 全部门禁通过"
